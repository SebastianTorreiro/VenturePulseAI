# VenturePulseAI — environment configuration template.
# Copy this file to `.env` and adjust values. `.env` is gitignored.
# Nested variables use the "__" delimiter: SECTION__FIELD.
# All variables are optional; the defaults below match local development.

# === Qdrant ===
# Vector database endpoint and the prefix used to name collections
# (final name is "<prefix>__<embedding model id>", see ADR-004).
QDRANT__URL=http://localhost:6333
QDRANT__COLLECTION_PREFIX=signals

# === Embedding ===
# Model that turns text into vectors. DIMENSIONS must match the model;
# changing the model requires re-indexing (ADR-004).
EMBEDDING__MODEL_ID=BAAI/bge-small-en-v1.5
EMBEDDING__DIMENSIONS=384

# === LLM ===
# provider: "ollama" (local, free) or "claude" (paid, requires API key).
LLM__PROVIDER=ollama
LLM__OLLAMA_HOST=http://localhost:11434
LLM__OLLAMA_MODEL=llama3.1:8b
# If LLM__PROVIDER=claude, uncomment and set your real key:
# LLM__CLAUDE_API_KEY=sk-ant-...
# LLM__CLAUDE_MODEL=claude-sonnet-4-6

# === Scraper ===
# RSS feed polled for funding signals, and the per-request timeout.
SCRAPER__RSS_FEED_URL=https://techcrunch.com/category/venture/feed/
SCRAPER__FETCH_TIMEOUT_SECONDS=30
